# Logs
# ==========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# docs/
# scripts/
# ==========================
# Database files
# ==========================
# *.sql
# *.sqllite
# Keep .db files
# !*.db
/migrations
# ==========================
# Uploads - keep folder and first layer
# ==========================

# Ignore everything inside uploads
uploads/**

# But keep the uploads folder itself
!uploads/

# Keep only first-level subfolders
!uploads/*/

# Ignore all files inside those subfolders
uploads/*/*

!.gitkeep


